{
  "$schema": "https://forgewright.dev/schemas/mcp-config.json",
  "project": "{{projectName}}",
  "generated_at": "{{generatedAt}}",
  "generated_by": "forgewright/mcp-generator",
  "forgewright_version": "{{forgewrightVersion}}",
  "transport": "stdio",
  "tools": {
    "query": {
      "enabled": true,
      "source": "gitnexus",
      "description": "Query the code knowledge graph by concept — returns ranked symbols with execution flows"
    },
    "context": {
      "enabled": true,
      "source": "gitnexus",
      "description": "360° view of a symbol — callers, callees, refs, process participation"
    },
    "impact": {
      "enabled": true,
      "source": "gitnexus",
      "description": "Blast radius analysis — d=1 WILL BREAK, d=2 LIKELY AFFECTED, d=3 MAY NEED TESTING"
    },
    "detect_changes": {
      "enabled": true,
      "source": "gitnexus",
      "description": "Pre-commit risk assessment — maps git diff to affected symbols and execution flows"
    },
    "rename": {
      "enabled": true,
      "source": "gitnexus",
      "description": "Safe multi-file rename using call-graph analysis"
    },
    "cypher": {
      "enabled": true,
      "source": "gitnexus",
      "description": "Custom Cypher-style graph queries for complex structural searches"
    },
    "route_map": {
      "enabled": true,
      "source": "gitnexus",
      "description": "API route → handler mappings with middleware chains"
    },
    "tool_map": {
      "enabled": true,
      "source": "gitnexus",
      "description": "MCP/RPC tool definitions and their implementations"
    },
    "shape_check": {
      "enabled": true,
      "source": "gitnexus",
      "description": "Check API response shapes against consumer property accesses"
    },
    "api_impact": {
      "enabled": true,
      "source": "gitnexus",
      "description": "Pre-change impact for API route handlers — consumers, middleware, risk"
    },
    "pr_review": {
      "enabled": true,
      "source": "gitnexus",
      "description": "PR blast-radius analysis — breaking changes, affected modules, reviewer recommendations"
    },
    "list_repos": {
      "enabled": true,
      "source": "gitnexus",
      "description": "List all indexed repositories with symbol/edge stats"
    }
  },
  "resources": {
    "project://profile": {
      "enabled": true,
      "source": ".forgewright/project-profile.json",
      "description": "Full project fingerprint — language, framework, health, patterns, risk"
    },
    "project://conventions": {
      "enabled": {{hasConventions}},
      "source": ".forgewright/code-conventions.md",
      "description": "Coding conventions and patterns detected in this project"
    }
  },
  "prompts": {
    "debug-issue": {
      "enabled": true,
      "description": "Structured debugging template using code intelligence"
    },
    "review-changes": {
      "enabled": true,
      "description": "Code review template with project conventions awareness"
    },
    "plan-feature": {
      "enabled": true,
      "description": "Feature planning template with architecture awareness"
    }
  }
}
