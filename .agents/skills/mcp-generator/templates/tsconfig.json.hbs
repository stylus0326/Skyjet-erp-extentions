{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "outDir": "./dist",
    "rootDir": ".",
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true
  },
  "include": ["*.ts", "tools/**/*.ts", "resources/**/*.ts", "prompts/**/*.ts", "utils/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
